HKCR
{
	NoRemove OpenUSD.USD
	{
		%PROPERTYDESCRIPTIONS%
	}

	NoRemove OpenUSD.USDA
	{
		%PROPERTYDESCRIPTIONS%
	}

	NoRemove OpenUSD.USDC
	{
		%PROPERTYDESCRIPTIONS%
	}

	NoRemove OpenUSD.USDZ
	{
		%PROPERTYDESCRIPTIONS%
	}

	NoRemove SystemFileAssociations
	{
		NoRemove .usd
		{
			%PROPERTYDESCRIPTIONS%
		}

		NoRemove .usda
		{
			%PROPERTYDESCRIPTIONS%
		}

		NoRemove .usdc
		{
			%PROPERTYDESCRIPTIONS%
		}

		NoRemove .usdz
		{
			%PROPERTYDESCRIPTIONS%
		}
	}

	NoRemove CLSID
	{
		ForceRemove %CLSID_SHELLPROPERTYSTORE% = s 'USD Property Store'
		{
			ForceRemove InProcServer32 = s '%MODULE%'
			{
				val ThreadingModel = s 'Apartment'
			}
			val DisplayName = s 'USD Property Store'
			val DisableProcessIsolation = d '1'
		}
	}
}

HKLM
{
	NoRemove Software
	{
		NoRemove Microsoft
		{
			NoRemove Windows
			{
				NoRemove CurrentVersion
				{
					NoRemove PropertySystem
					{
						NoRemove PropertyHandlers
						{
							ForceRemove .usd = s '%CLSID_SHELLPROPERTYSTORE%'
							ForceRemove .usda = s '%CLSID_SHELLPROPERTYSTORE%'
							ForceRemove .usdc = s '%CLSID_SHELLPROPERTYSTORE%'
							ForceRemove .usdz = s '%CLSID_SHELLPROPERTYSTORE%'
						}
					}

					NoRemove 'Shell Extensions'
					{
						NoRemove Approved
						{
							ForceRemove val %CLSID_SHELLPROPERTYSTORE% = s 'USD Property Store'
						}
					}
				}
			}
		}
	}
}

